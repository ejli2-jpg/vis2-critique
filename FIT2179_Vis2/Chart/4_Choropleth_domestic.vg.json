{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Domestic overnight trips by state",
    "subtitle": "Year ending December 2024 | Source: TRA National Visitor Survey",
    "anchor": "start",
    "fontSize": 15,
    "subtitleFontSize": 11,
    "subtitleColor": "#666"
  },
  "width": 600,
  "height": 450,
  "projection": {
    "type": "mercator",
    "center": [133, -28],
    "scale": 620
  },
  "layer": [
    {
      "data": {
        "url": "../Data/au-states-topo.json",
        "format": { "type": "topojson", "feature": "states" }
      },
      "transform": [
        {
          "lookup": "properties.STATE_NAME",
          "from": {
            "data": { "url": "../Data/domestic_by_state.csv" },
            "key": "state",
            "fields": ["trips_millions", "spend_billion_aud", "nights_millions"]
          }
        }
      ],
      "mark": { "type": "geoshape", "stroke": "#ffffff", "strokeWidth": 1.5 },
      "encoding": {
        "color": {
          "field": "trips_millions",
          "type": "quantitative",
          "title": "Overnight trips (M)",
          "scale": { "scheme": "oranges", "domain": [0, 42] },
          "legend": {
            "orient": "bottom-left",
            "titleFontSize": 11,
            "labelFontSize": 10,
            "gradientLength": 140
          }
        },
        "tooltip": [
          { "field": "properties.STATE_NAME", "title": "State / Territory" },
          { "field": "trips_millions", "title": "Overnight trips (millions)", "format": ".1f" },
          { "field": "nights_millions", "title": "Visitor nights (millions)", "format": ".1f" },
          { "field": "spend_billion_aud", "title": "Spend ($B AUD)", "format": ".1f" }
        ]
      }
    },
    {
      "data": {
        "values": [
          {
            "lon": 146,
            "lat": -32,
            "text": "NSW accounts for 33% of all domestic overnight trips"
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 10,
        "fontStyle": "italic",
        "color": "#333333",
        "fontWeight": "bold"
      },
      "encoding": {
        "longitude": { "field": "lon", "type": "quantitative" },
        "latitude": { "field": "lat", "type": "quantitative" },
        "text": { "field": "text" }
      }
    }
  ],
  "config": { "view": { "stroke": null }, "background": "#f0f7fb" }
}